# =============================================================================
# PRANELY - Production Environment Template
# COPY THIS FILE TO .env.production AND FILL IN YOUR VALUES
# NEVER COMMIT .env.production TO VERSION CONTROL
# =============================================================================

# -----------------------------------------------------------------------------
# Security (REQUIRED - Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))")
# Minimum 64 characters for production
# -----------------------------------------------------------------------------
SECRET_KEY=<INSERT_64_CHAR_SECRET_KEY_HERE>

# -----------------------------------------------------------------------------
# Database (REQUIRED)
# Note: In Docker, DATABASE_URL is overridden with POSTGRES_PASSWORD from docker-compose
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql+asyncpg://<USER>:<PASSWORD>@<HOST>:<PORT>/<DB_NAME>

# -----------------------------------------------------------------------------
# Redis (REQUIRED)
# -----------------------------------------------------------------------------
REDIS_URL=redis://<HOST>:<PORT>

# -----------------------------------------------------------------------------
# Stripe (REQUIRED for billing in production)
# -----------------------------------------------------------------------------
# API Key from Stripe Dashboard > Developers > API keys
STRIPE_SECRET_KEY=sk_live_<YOUR_STRIPE_LIVE_KEY>

# Webhook secret from Stripe Dashboard > Developers > Webhooks
STRIPE_WEBHOOK_SECRET=whsec_<YOUR_WEBHOOK_SECRET>

# Frontend URL for Stripe redirect URLs (HTTPS required)
FRONTEND_URL=https://app.pranely.com

# -----------------------------------------------------------------------------
# Application (Production settings)
# -----------------------------------------------------------------------------
ENV=production
DEBUG=false
LOG_LEVEL=warning
