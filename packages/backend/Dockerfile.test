# Dockerfile for PRANELY Backend Test Container
FROM python:3.12.7-slim
WORKDIR /app

# Install dependencies
RUN pip install poetry==1.8.3
COPY pyproject.toml poetry.lock* ./
RUN poetry config virtualenvs.create false && \
    poetry install --no-interaction --all-extras

# Install pytest for tests
RUN pip install pytest pytest-asyncio pytest-cov pytest-mock

# Copy full app including tests
COPY . .

EXPOSE 8000
CMD ["python", "-m", "pytest", "tests/", "--ignore=tests/test_api_v1/test_command.py", "--ignore=tests/test_residues_api.py", "--ignore=tests/test_transporters_api.py", "--ignore=tests/test_waste_api.py", "--ignore=tests/test_health.py", "-v", "--tb=short"]