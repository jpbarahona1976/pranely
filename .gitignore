# =============================================================================
# PRANELY - .gitignore
# Monorepo: Next.js 15 + FastAPI + Python 3.12 + Docker
# =============================================================================

# =============================================================================
# NODE.JS - Frontend (packages/frontend)
# =============================================================================
packages/frontend/node_modules/
packages/frontend/.next/
packages/frontend/out/
packages/frontend/build/
packages/frontend/dist/
packages/frontend/next-env.d.ts
.pnp
.pnp.js
.yarn/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
*.tsbuildinfo

# =============================================================================
# PYTHON - Backend (packages/backend)
# =============================================================================
packages/backend/__pycache__/
packages/backend/*.py[cod]
packages/backend/venv/
packages/backend/.venv/
packages/backend/env/
packages/backend/*.egg-info/
packages/backend/dist/
packages/backend/build/
.pytest_cache/
.mypy_cache/
.coverage
htmlcov/
.tox/
.nox/

# =============================================================================
# DOCKER
# =============================================================================
.docker/
docker-compose.override.yml

# =============================================================================
# BASES DE DATOS
# =============================================================================
*.db
*.sqlite
*.sqlite3

# =============================================================================
# IDEs
# =============================================================================
.vscode/
.idea/
*.swp
*.swo
*~

# =============================================================================
# SECRETS (CRÍTICO)
# =============================================================================
*.pem
*.key
*.crt
.env
.env.*
.env.local
.env.production
secrets.json
credentials.json
service-account.json

# =============================================================================
# UPLOADS y TEMPORALES
# =============================================================================
uploads/
*.tmp
*.temp
*.cache
*.bak
*.log
logs/

# =============================================================================
# TESTING
# =============================================================================
test-results/
playwright-report/
videos/
screenshots/
coverage/

# =============================================================================
# BUILD OUTPUTS
# =============================================================================
.next/
out/
dist/
build/
target/

# =============================================================================
# OS
# =============================================================================
.DS_Store
Thumbs.db
