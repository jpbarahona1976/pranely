# =============================================================================
# PRANELY - .gitignore
# =============================================================================

# -----------------------------------------------------------------------
# Environment files (SECURITY: Never commit secrets)
# -----------------------------------------------------------------------
.env
.env.*
.env.local
.env.production
.env.staging
.env.development
!.env.example
!.env.production.example
!.env.staging

# -----------------------------------------------------------------------
# Python
# -----------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
.env/
venv/
ENV/
env/
.venv/

# -----------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
*.db
test_pranely*.db

# -----------------------------------------------------------------------
# IDE
# -----------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# -----------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------
*.log
logs/
gitleaks_output.txt

# -----------------------------------------------------------------------
# Alembic (generated files)
# -----------------------------------------------------------------------
alembic/versions/__pycache__/
alembic/__pycache__/

# -----------------------------------------------------------------------
# Scratch files (development only)
# -----------------------------------------------------------------------
packages/backend/scratch_*.py
packages/backend/test_import.py
packages/backend/validate_*.py
scratch_*.py
test_import.py
validate_*.py\"packages/frontend/.pnpm-store\"  
